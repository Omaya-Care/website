{
  "name": "omaya-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/entry-server.tsx --outDir dist-server && node scripts/prerender.mjs",
    "build:client": "vite build",
    "start": "vite preview",
    "preview:test": "vite preview --port 4188 --strictPort",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "beasties": "^0.4.3",
    "playwright": "^1.61.1",
    "react-doctor": "^0.7.8",
    "tailwindcss": "^4",
    "typescript": "5.7.3",
    "vite": "^6.4.3"
  }
}
